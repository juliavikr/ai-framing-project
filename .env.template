ANTHROPIC_API_KEY=

# ── NewsAPI (https://newsapi.org — free tier or paid developer plan) ───────────
NEWS_API_KEY=

# ── Snowflake ──────────────────────────────────────────────────────────────────
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=AI_FRAMING
